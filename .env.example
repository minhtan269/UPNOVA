GEMINI_API_KEY=your_gemini_api_key_here
EMAPS_TOKEN=your_electricitymaps_token_here

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/acrm_db

# NextAuth Authentication
NEXTAUTH_SECRET=your-secret-key-here-min-32-characters
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
# Get these from https://console.cloud.google.com/
GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_SECRET=your-google-client-secret

